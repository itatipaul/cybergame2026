+BUILTIN(ArrayPrototypeCompactMapFast) {
+  HandleScope scope(isolate);
+
+  Handle<Object> receiver = args.receiver();
+  Handle<Object> callback_obj = args.atOrUndefined(isolate, 1);
+  Handle<Object> this_arg = args.atOrUndefined(isolate, 2);
+
+  if (!IsCallable(*callback_obj)) {
+    THROW_NEW_ERROR_RETURN_FAILURE(
+        isolate,
+        NewTypeError(MessageTemplate::kCalledNonCallable, callback_obj));
+  }
+
+  // Experimental numeric compaction path. It deliberately accepts only short,
+  // packed-double arrays and optimized JS callbacks; other cases use the empty
+  // conservative result used by the prototype experiment.
+  if (!IsJSArray(*receiver) || !IsJSFunction(*callback_obj)) {
+    return *isolate->factory()->NewJSArray(0);
+  }
+
+  Handle<JSArray> array = Handle<JSArray>::cast(receiver);
+  Handle<JSFunction> callback = Handle<JSFunction>::cast(callback_obj);
+
+  uint32_t length = 0;
+  if (!Object::ToArrayLength(array->length(), &length) ||
+      length > 0x400 ||
+      array->GetElementsKind() != PACKED_DOUBLE_ELEMENTS ||
+      isolate->IsAnyInitialArrayPrototype(*array) ||
+      !callback->HasAttachedOptimizedCode(isolate)) {
+    return *isolate->factory()->NewJSArray(0);
+  }
+
+  // Snapshot the numeric source once. The callback is expected to be pure for
+  // this experimental path, but it is still invoked as normal JS.
+  Handle<FixedDoubleArray> source(FixedDoubleArray::cast(array->elements()),
+                                  isolate);
+  length = std::min(length, static_cast<uint32_t>(source->length()));
+
+  uint32_t to = 0;
+  Handle<Object> call_args[3];
+  for (uint32_t k = 0; k < length; k++) {
+    if (source->is_the_hole(static_cast<int>(k))) continue;
+
+    call_args[0] =
+        isolate->factory()->NewNumber(source->get_scalar(static_cast<int>(k)));
+    call_args[1] = isolate->factory()->NewNumberFromUint(k);
+    call_args[2] = array;
+
+    Handle<Object> mapped;
+    ASSIGN_RETURN_FAILURE_ON_EXCEPTION(
+        isolate, mapped,
+        Execution::Call(isolate, callback_obj, this_arg, 3, call_args));
+
+    if (IsUndefined(*mapped, isolate)) continue;
+
+    // Reuse the receiver's storage as a temporary compaction buffer. The
+    // generic element store keeps the prototype experiment usable across
+    // number and object callback results.
+    Handle<Object> ignored;
+    ASSIGN_RETURN_FAILURE_ON_EXCEPTION(
+        isolate, ignored,
+        Object::SetElement(isolate, array, to, mapped,
+                           ShouldThrow::kThrowOnError));
+    to++;
+  }
+
+  // The compaction result should carry the post-callback elements kind. This
+  // prototype instead reuses the initial packed-double map while publishing the
+  // receiver's current elements backing store.
+  Handle<FixedArrayBase> aliased_elements(array->elements(), isolate);
+  Handle<JSArray> result = isolate->factory()->NewJSArrayWithElements(
+      aliased_elements, PACKED_DOUBLE_ELEMENTS, static_cast<int>(to),
+      AllocationType::kYoung);
+  return *result;
+}
